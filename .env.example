PORT=8080
# Base URL of the Go backend (uigraph-api), no trailing slash
UIGRAPH_API_URL=http://localhost:8081
# S3 / MinIO bucket the gateway presigns uploads into (docs, frame images)
S3_BUCKET=uigraph-gateway-uploads
S3_REGION=us-east-1
# For MinIO local dev only:
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are read from the standard AWS env
