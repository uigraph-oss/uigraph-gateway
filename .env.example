PORT=8080
# Base URL of the Go backend (uigraph-api), no trailing slash
UIGRAPH_API_URL=http://localhost:8081

# Object storage the gateway presigns uploads into (docs, frame images).
# Works with AWS S3, Cloudflare R2, MinIO, and any S3-compatible provider.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=uigraph
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
# Path-style addressing. Required for MinIO and Cloudflare R2; set to false for
# AWS S3 virtual-hosted style. Defaults to true.
STORAGE_FORCE_PATH_STYLE=true
# Browser-reachable storage host used to sign presigned URLs. Leave blank to
# reuse STORAGE_ENDPOINT.
# STORAGE_PUBLIC_ENDPOINT=
